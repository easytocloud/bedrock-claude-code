{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-extension",
      "type": "shell",
      "command": "npm run watch:tsc",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
