{
  "name": "claude-personae-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Claude Code Personae — VS Code extension + CLI, sharing one preset-resolution engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/easytocloud/bedrock-claude-code"
  },
  "workspaces": [
    "core",
    "extension",
    "cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w @easytocloud/claude-personae-core",
    "build:extension": "npm run build -w bedrock-claude-code",
    "build:cli": "npm run build -w @easytocloud/claude-personae",
    "compile": "npm run compile --workspaces --if-present",
    "lint": "npm run lint -w bedrock-claude-code --if-present",
    "package:extension": "npm run package -w bedrock-claude-code",
    "publish:extension": "npm run publish -w bedrock-claude-code",
    "publish:cli": "npm publish -w @easytocloud/claude-personae --access public"
  }
}
