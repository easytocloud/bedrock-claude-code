    "watch": "node esbuild.js --watch",
    "prepublishOnly": "node esbuild.js"
  },
  "devDependencies": {
    "@easytocloud/claude-personae-core": "*",
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
